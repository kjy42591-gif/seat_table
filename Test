        generateOrderedChart();
      }, []);

      const handlePrint = () => {
        try { window.print(); } catch (err) {}
        setShowPrintModal(true);
      };

      const loadHistory = (item) => {
        setRows(item.r);
        setCols(item.c);
        if (item.pairMode !== undefined) setIsPairMode(item.pairMode);
        setSeatingChart(item.layout);
        setShowHistoryModal(false);
        setStatus({ type: "success", text: "이전 기록을 완벽하게 복구했습니다." });
      };

      const getGridTemplateColumns = () => {
        if (!isPairMode) return `repeat(${cols}, minmax(0, 1fr))`;
        
        let colArr = [];
        for (let c = 0; c < cols; c++) {
          colArr.push("minmax(0, 1fr)");
          if (c % 2 === 1 && c !== cols - 1) {
            colArr.push("var(--aisle-width)"); 
          }
        }
        return colArr.join(" ");
      };

