    const HistoryIcon = ({size=24, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>;
    const Printer = ({size=24, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>;
    const X = ({size=24, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>;

    // ----- 기본 명단 -----
    const defaultStudents = `20701 권서준(남)
20702 권예원(여)
20703 김규비(여)
20704 김민주(남)
20705 김빛나(여)
20706 김사랑(여)
20707 김서인(여)
20708 김서진(여)
20709 김준석(남)
20710 김지한(남)
20711 김채원(여)
20712 박수호(남)
20713 백상헌(남)
20714 변준서(남)
20715 윤도담(남)
20716 윤유주(여)
20717 이성훈(남)
20719 이유진(여)
20720 이재윤(남)
20721 이채원(여)
20722 임은서(여)
20723 장인준(남)
20724 전민준(남)
20725 전은채(남)
20726 정윤서(여)
20727 조예진(여)
20728 조제형(남)
20729 채민준(남)
20730 최예린(여)
20731 안재익(남)`;

    function App() {
      const [rows, setRows] = useState(5);
      const [cols, setCols] = useState(6);
      const [isPairMode, setIsPairMode] = useState(true);
      const [preferMixedGender, setPreferMixedGender] = useState(true);
      const [useRotationCompensate, setUseRotationCompensate] = useState(false);
      const [studentInput, setStudentInput] = useState(defaultStudents);
      const [seatingChart, setSeatingChart] = useState([]);
      const [status, setStatus] = useState({ type: "", text: "" });
      const [isAnimating, setIsAnimating] = useState(false);
      const [showPrintModal, setShowPrintModal] = useState(false);
      
      const [history, setHistory] = useState([]);
      const [showHistoryModal, setShowHistoryModal] = useState(false);

      // 클라우드 데이터베이스 상태
      const [db, setDb] = useState(null);
      const [user, setUser] = useState(null);

      // 1. Firebase 인증 및 DB 초기화 (Rule 3 준수)
      useEffect(() => {
        if (typeof __firebase_config === 'undefined' || !__firebase_config) {
          console.log("로컬 단독 실행 모드: 클라우드 연동을 건너뛰고 오프라인 모드로 자동 전환합니다.");
          return;
        }
        try {
          const firebaseConfig = JSON.parse(__firebase_config);
          const app = initializeApp(firebaseConfig);
          const auth = getAuth(app);
          const firestoreDb = getFirestore(app);
          setDb(firestoreDb);

          const initAuth = async () => {
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
              await signInWithCustomToken(auth, __initial_auth_token);
            } else {
              await signInAnonymously(auth);
            }
          };
          initAuth().catch(err => console.error("인증 실패:", err));

          const unsubscribe = onAuthStateChanged(auth, setUser);
          return () => unsubscribe();
        } catch (err) {
          console.error("Firebase 초기화 에러:", err);
        }
      }, []);

      // 2. 실시간 배치 기록 클라우드 동기화 (Rule 1 & Rule 3 준수)
      useEffect(() => {
        if (!db || !user) return;
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
        const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'history', 'main');

        const unsubscribe = onSnapshot(docRef, (docSnap) => {
          if (docSnap.exists()) {
            const data = docSnap.data();
            if (data && data.records) {
              setHistory(data.records);
              console.log("클라우드 배치 기록이 성공적으로 동기화되었습니다.");
            }
          }
        }, (error) => {
          console.error("클라우드 데이터 로드 실패:", error);
        });

        return () => unsubscribe();
      }, [db, user]);

      // 3. 기록 추가 시 클라우드 자동 저장 프로세스
      const updateHistoryAndSave = async (newHistory) => {
        setHistory(newHistory);
        if (!db || !user) return; // 오프라인 모드인 경우 로컬 메모리에만 유지

        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
        const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'history', 'main');
        try {
          await setDoc(docRef, { records: newHistory });
        } catch (err) {
          console.error("클라우드 자동 저장 에러:", err);
        }
      };

      // 오프라인 로컬 백업 내보내기 (JSON 형태로 텍스트 파일 다운로드)
      const exportHistoryToFile = () => {
        if (history.length === 0) {
          alert("내보낼 자리배치 기록이 존재하지 않습니다.");
          return;
        }
        const dataStr = JSON.stringify(history, null, 2);
        const blob = new Blob([dataStr], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;
        link.download = `우리반_좌석배치기록_백업_${new Date().toISOString().slice(0,10)}.txt`;
        link.click();
        URL.revokeObjectURL(url);
      };

      // 오프라인 로컬 백업 가져오기
      const importHistoryFromFile = (event) => {
        const file = event.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (e) => {
          try {
            const imported = JSON.parse(e.target.result);
            if (Array.isArray(imported)) {
              updateHistoryAndSave(imported);
              alert("백업 파일로부터 자리배치 기록을 완벽하게 가져왔습니다!");
            } else {
              alert("올바르지 않은 백업 파일 형식입니다.");
            }
          } catch (err) {
            alert("파일을 읽는 과정에서 에러가 발생했습니다.");
          }
        };
        reader.readAsText(file);
      };

      const parseStudents = (input) => {
        return input.split('\n').map(line => {
          const trimmed = line.trim();
          if (!trimmed) return null;
          
          const match = trimmed.match(/^(\d+)\s+([가-힣]+).*?(남|여)/);
          if (match) {
            return { id: match[1], name: match[2], gender: match[3], original: trimmed };
          }
          const parts = trimmed.split(' ');
          return { id: parts[0] || '', name: parts[1] || trimmed, gender: '알수없음', original: trimmed };
        }).filter(Boolean);
      };

      // 좌석 배치별 규칙 만족도(비용) 연산 함수 (구석 방지 명단 삭제됨)
      const getCost = (layout, rCount, cCount, avoidStudents = []) => {
        let hardCost = 0; 
        let softCost = 0; 

        const getRC = (idx) => [Math.floor(idx / cCount), idx % cCount];
        
        const isAdjacent = (i1, i2) => {
          const [r1, c1] = getRC(i1);
          const [r2, c2] = getRC(i2);
          return Math.abs(r1 - r2) + Math.abs(c1 - c2) === 1;
        };

        const isPartner = (i1, i2) => {
          const [r1, c1] = getRC(i1);
          const [r2, c2] = getRC(i2);
          return r1 === r2 && Math.floor(c1 / 2) === Math.floor(c2 / 2);
        };

        const getIdx = (name) => layout.findIndex(s => s && s.name === name);

        // ================= [좌석 순환 보정 로직 (직전 가장자리 학생 방지)] =================
        if (avoidStudents.length > 0) {
          avoidStudents.forEach(name => {
            const idx = getIdx(name);
            if (idx !== -1) {
              const [r, c] = getRC(idx);
              // 선생님의 솔루션 반영: 맨 앞줄(r === 0)과 맨 뒷줄(r === rCount - 1)만 가장자리로 제한
              if (r === 0 || r === rCount - 1) {
                hardCost += 1; 
              }
            }
          });
        }

        if (!isPairMode) {
          // ================= [일반배열 전용 규칙] =================
          const bannedPairsGeneral = [
            ["김규비", "최예린"], ["김규비", "김준석"],
            ["김규비", "이성훈"], ["김규비", "이채원"],
            ["윤유주", "김채원"], ["전민준", "김준석"],
            ["김빛나", "채민준"]
          ];
          for (let [n1, n2] of bannedPairsGeneral) {
            const i1 = getIdx(n1);
            const i2 = getIdx(n2);
            if (i1 !== -1 && i2 !== -1 && isAdjacent(i1, i2)) {
              hardCost += 1;
            }
          }

          for (let i = 0; i < layout.length; i++) {
            if (!layout[i] || layout[i].gender === '알수없음') continue;
            const [r, c] = getRC(i);
            const neighbors = [
              i - cCount, i + cCount,
              (c > 0) ? i - 1 : -1,
              (c < cCount - 1) ? i + 1 : -1
            ].filter(ni => ni >= 0 && ni < layout.length && isAdjacent(i, ni));

            let sameGender = 0;
            for (let ni of neighbors) {
              if (layout[ni] && layout[ni].gender === layout[i].gender) {
                sameGender++;
              }
            }
            if (sameGender > 2) {
              softCost += (sameGender - 2) * 10; 
            }
          }

        } else {
          // ================= [짝꿍배열 전용 규칙] =================
          const bannedPairsPairMode = [
            ["이성훈", "김규비"], ["이성훈", "최예린"], ["이성훈", "이채원"],
            ["조제형", "김규비"], ["조제형", "최예린"], ["조제형", "이채원"],
            ["김빛나", "채민준"], ["전민준", "김준석"], ["윤유주", "김채원"],
            ["김준석", "김규비"],
            ["조예진", "임은서"]
          ];
          for (let [n1, n2] of bannedPairsPairMode) {
            const i1 = getIdx(n1);
            const i2 = getIdx(n2);
            if (i1 !== -1 && i2 !== -1 && isPartner(i1, i2)) {
              hardCost += 1; 
            }
          }

          if (preferMixedGender) {
            for (let r = 0; r < rCount; r++) {
              for (let p = 0; p < Math.floor(cCount / 2); p++) {
                const i1 = r * cCount + p * 2;
                const i2 = r * cCount + p * 2 + 1;
                const s1 = layout[i1];
                const s2 = layout[i2];
                
                if (s1 && s2 && s1.gender !== '알수없음' && s2.gender !== '알수없음') {
                  if (s1.gender === s2.gender) {
                    softCost += 50; 
                  }
                }
              }
            }
          }
        }

        return hardCost * 1000 + softCost;
      };

      const generateRandomChart = () => {
        if (isAnimating) return;
        setStatus({ type: "info", text: "경우의 수를 연산하며 최적의 배치를 산출 중입니다..." });
        
        setTimeout(() => {
          const parsed = parseStudents(studentInput);
          const totalSeats = rows * cols;

          if (parsed.length > totalSeats) {
            setStatus({ type: "error", text: `학생 수(${parsed.length}명)가 좌석 수(${totalSeats}개)보다 많습니다.` });
            return;
          }

          let avoidStudents = [];
          if (useRotationCompensate && history.length > 0) {
            const prev = history[0]; 
            const prevLayout = prev.layout;
            const prevRows = prev.r;
            const prevCols = prev.c;

            prevLayout.forEach((student, idx) => {
              if (!student) return;
              const r = Math.floor(idx / prevCols);
              const c = idx % prevCols;

              // 맨 앞줄, 맨 뒷줄에 앉았던 학생 12명만 추출 (좌우 끝 열 제외)
              if (r === 0 || r === prevRows - 1) {
                avoidStudents.push(student.name);
              }
            });
          }

          let bestLayout = null;
          let bestCost = Infinity;

          for (let attempt = 0; attempt < 8; attempt++) {
            let currentLayout = [...parsed];
            while (currentLayout.length < totalSeats) currentLayout.push(null);

            for (let i = currentLayout.length - 1; i > 0; i--) {
              const j = Math.floor(Math.random() * (i + 1));
              [currentLayout[i], currentLayout[j]] = [currentLayout[j], currentLayout[i]];
            }

            let currentBest = [...currentLayout];
            let currentBestCost = getCost(currentBest, rows, cols, avoidStudents);

            for (let step = 0; step < 60000; step++) {
              if (currentBestCost === 0) break;

              const nextLayout = [...currentBest];
              const idx1 = Math.floor(Math.random() * nextLayout.length);
              const idx2 = Math.floor(Math.random() * nextLayout.length);
              
              [nextLayout[idx1], nextLayout[idx2]] = [nextLayout[idx2], nextLayout[idx1]];

              const nextCost = getCost(nextLayout, rows, cols, avoidStudents);

              if (nextCost < currentBestCost) {
                currentBest = nextLayout;
                currentBestCost = nextCost;
              } else if (nextCost === currentBestCost && Math.random() < 0.25) {
                currentBest = nextLayout;
              } else if (Math.random() < 0.005) {
                currentBest = nextLayout;
                currentBestCost = nextCost;
              }
            }

            if (currentBestCost < bestCost) {
              bestCost = currentBestCost;
              bestLayout = currentBest;
            }

            if (bestCost === 0) break;
          }

          if (bestCost >= 1000) {
            setStatus({ type: "error", text: "⚠️ 직전 배치 맨 앞/맨 뒷줄 학생 중복 배치 방지 규칙 조건이 엉켜 일부 규칙을 만족하지 못했습니다. 다시 한 번 섞어주세요!" });
            setSeatingChart(bestLayout);
            return;
          } else {
            let successMsg = "✨ 성공! 모든 금지 규칙과 학생 배치 기준을 완벽하게 해결했습니다!";
            if (avoidStudents.length > 0) {
              successMsg += ` (직전 배치 맨 앞/맨 뒷줄에 앉았던 ${avoidStudents.length}명은 이번에 무조건 두 번째~네 번째 줄로 안전하게 순환 배치되었습니다.)`;
            }
            setStatus({ type: "success", text: successMsg });
          }

          setIsAnimating(true);
          setSeatingChart(Array(totalSeats).fill(null));

          const studentsToReveal = bestLayout
            .filter(s => s !== null)
            .sort((a, b) => parseInt(a.id) - parseInt(b.id));

          let currentStep = 0;
          const intervalId = setInterval(() => {
            if (currentStep >= studentsToReveal.length) {
              clearInterval(intervalId);
              setSeatingChart(bestLayout);
              setIsAnimating(false);
              
              const now = new Date();
              const dateString = `${now.getMonth() + 1}월 ${now.getDate()}일 ${now.getHours()}시 ${now.getMinutes()}분`;
              const newRecord = { id: Date.now(), date: dateString, layout: bestLayout, r: rows, c: cols, pairMode: isPairMode };
              
              // 클라우드/로컬 상태 동시 업데이트
              updateHistoryAndSave([newRecord, ...history]);
              return;
            }

            const student = studentsToReveal[currentStep];
            const targetIndex = bestLayout.findIndex(s => s && s.id === student.id);

            setSeatingChart(prev => {
              const next = [...prev];
              next[targetIndex] = student;
              return next;
            });

            currentStep++;
          }, 1000);
          
        }, 10);
      };

      const generateOrderedChart = () => {
        if (isAnimating) return;
        const parsed = parseStudents(studentInput);
        let layout = [...parsed];
        
        layout.sort((a, b) => parseInt(a.id) - parseInt(b.id));
        while (layout.length < rows * cols) layout.push(null);
        
        setSeatingChart(layout);
        setStatus({ type: "", text: "" });
      };

