          textColor = "text-yellow-900";
        }

        return (
          <div key={index} style={{ gridColumn: gridCol }} className={`print-card w-full h-full min-h-[4rem] sm:min-h-[5rem] flex flex-col items-center justify-center rounded-lg shadow-sm border-2 transition-all duration-300 ${bgColor} ${borderColor}`}>
